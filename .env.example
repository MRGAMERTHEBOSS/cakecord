# Example .env file for CakeCord Site
# Copy this to .env and fill in your values

# Frontend (website) port (used by Docker only)
PORT=3040

# Discord bot token for Team API
DISCORD_BOT_TOKEN=your_bot_token_here

# Team API server port (should NOT be 3040 if running with Docker frontend)
TEAM_API_PORT=3050

# Frontend uses this to fetch team data (must match API port)
VITE_TEAM_API_URL=http://localhost:3050/api/team

# Local API base URL for Stripe checkout server
VITE_API_BASE_URL=http://localhost:4242

# Stripe checkout configuration
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PRICE_ID=price_your_price_id_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Optional explicit return URL after checkout completion
# STRIPE_RETURN_URL=http://localhost:5173/premium?checkout=success&session_id={CHECKOUT_SESSION_ID}
